{
  "schema": "glic-metal-integration-v1",
  "library": {
    "name": "GlicMetal",
    "cmake_target": "GlicMetal::GlicMetal",
    "swift_module": "GlicMetal",
    "language_abi": "C",
    "abi_versions": {"image": 1, "codec": 1, "selected_presets": 1}
  },
  "distribution": {
    "macos_sdk": {
      "library": "GlicMetal.xcframework",
      "resources": "GlicMetalResources.bundle",
      "documentation_directory": "Documentation",
      "offline_tools_directory": "Tools",
      "python_requirements": "Tools/requirements.txt"
    },
    "cmake_package": {
      "target": "GlicMetal::GlicMetal",
      "resource_copy_function": "glic_metal_copy_resources",
      "offline_tools_variable": "GLIC_METAL_TOOLS_DIR",
      "python_requirements_variable": "GLIC_METAL_PYTHON_REQUIREMENTS"
    }
  },
  "public_headers": [
    "glic_metal/glic_metal.h",
    "glic_metal/glic_metal_metal.h",
    "glic_metal/codec_glitch.h",
    "glic_metal/glitch_presets.h"
  ],
  "selected_preset_bank": {
    "resource": "selected-presets.json",
    "runtime_source": "compiled_c_api",
    "count": 19,
    "category_counts": {"original": 14, "spatial": 4, "codec": 1},
    "enumerate": "glic_glitch_preset_count + glic_glitch_preset_get",
    "lookup": "glic_glitch_preset_find"
  },
  "lanes": {
    "original": {
      "execution": "synchronous",
      "input": "BGRA8_or_RGBA8_CPU_buffer",
      "context": "glic_metal_context",
      "apply": "glic_glitch_preset_apply_metal",
      "prepare": "glic_metal_prepare",
      "process": "glic_metal_process_frame",
      "mode": "GLIC_METAL_MODE_ORIGINAL",
      "required_resources": ["Presets", "glic_realtime.metallib"]
    },
    "spatial": {
      "execution": "synchronous",
      "input": "BGRA8_or_RGBA8_CPU_buffer_or_BGRA8Unorm_MTLTexture",
      "context": "glic_metal_context",
      "apply": "glic_glitch_preset_apply_metal",
      "prepare": "glic_metal_prepare",
      "process": "glic_metal_process_frame_or_texture_api",
      "mode": "GLIC_METAL_MODE_COMPAT_REALTIME",
      "required_resources": ["Presets", "glic_realtime.metallib"]
    },
    "codec": {
      "execution": "asynchronous",
      "input": "CVPixelBufferRef_32BGRA",
      "context": "glic_codec_glitch_context",
      "apply": "glic_glitch_preset_apply_codec",
      "prepare": "glic_codec_glitch_prepare",
      "process": "glic_codec_glitch_submit_pixel_buffer",
      "output": "glic_codec_glitch_copy_latest_pixel_buffer",
      "native_codecs": ["h264", "hevc", "prores_422"],
      "codec_selector": "glic_codec_glitch_config.codec",
      "implementation_level": "glic_codec_glitch_effect_implementation_level",
      "implementation_contract": "VideoToolbox encoded samples are decoded cleanly; realtime visual reconstruction does not mutate compressed payload bytes.",
      "effect_count": 36,
      "effect_names": [
        "qp_pump", "bitrate_crush", "slice_dropout", "slice_transplant",
        "pframe_loss", "idr_starvation", "payload_xor",
        "reference_timewarp", "codec_feedback", "generation_cascade",
        "resolution_hop", "chroma_codec_echo", "temporal_polyphony",
        "intra_cannibalism", "residual_rift", "codec_grain_synth",
        "recursive_codec_skin", "concealment_choreography",
        "dual_codec_crossbreed", "codec_pingpong", "gop_accordion",
        "bframe_braid", "plane_split_codec", "roi_quality_islands",
        "codec_phase_mosaic", "encoder_hot_swap", "pts_rubberband",
        "bitrate_raster", "plane_time_split", "reference_atlas",
        "flow_lattice", "scan_order_fold", "regional_gop_clock",
        "entropy_feedback", "rolling_time_shutter",
        "asymmetric_plane_codec"
      ],
      "required_resources": []
    }
  },
  "offline_workflows": {
    "codec_generations": {
      "execution": "offline_process",
      "entrypoint": "scripts/process_multicodec_glitch.py",
      "sdk_entrypoint": "Tools/process_multicodec_glitch.py",
      "codecs": [
        "av1", "av2", "hevc", "vp9", "prores", "vvc", "theora", "dirac"
      ],
      "software_codecs": {
        "av1": "FFmpeg_libaom-av1_plus_libdav1d",
        "vp9": "FFmpeg_libvpx-vp9",
        "av2": "AOMedia_AVM_v1.0.0_reference",
        "vvc": "Fraunhofer_VVenC_v1.14.0_reference",
        "theora": "FFmpeg_libtheora",
        "dirac": "FFmpeg_VC2_Dirac"
      },
      "persistent_evidence": [
        "compressed_bitstream",
        "decoded_intermediate",
        "sha256",
        "codec_probe",
        "timings",
        "json_report"
      ],
      "realtime_claim": false
    },
    "packet_glitch_lab": {
      "execution": "offline_isolated_process",
      "entrypoint": "scripts/process_offline_packet_glitch.py",
      "sdk_entrypoint": "Tools/process_offline_packet_glitch.py",
      "catalog": "resources/offline-codec-effects.json",
      "evaluator": "scripts/evaluate_offline_packet_glitches.py",
      "sdk_evaluator": "Tools/evaluate_offline_packet_glitches.py",
      "codecs": ["h264", "hevc", "av1", "vp9", "prores"],
      "effects": [
        "packet_bit_rot",
        "gop_amputation",
        "packet_dropout_score",
        "timestamp_fracture",
        "nal_obu_surgery",
        "header_hallucination",
        "packet_transplant",
        "vp9_superframe_shuffle"
      ],
      "isolation": {
        "subprocess": true,
        "timeout": true,
        "cpu_limit": true,
        "file_size_limit": true,
        "decoder_threads": 1
      },
      "persistent_evidence": [
        "source_bitstream",
        "damaged_bitstream",
        "salvaged_intermediate",
        "decoder_log",
        "sha256",
        "codec_probe",
        "json_report"
      ],
      "may_produce_invalid_bitstream": true,
      "realtime_claim": false
    },
    "codec_syntax_lab": {
      "execution": "offline_process",
      "entrypoint": "scripts/process_codec_lab.py",
      "sdk_entrypoint": "Tools/process_codec_lab.py",
      "catalog": "resources/codec-lab-effects.json",
      "effect_count": 13,
      "implementation_contract": "decoded reconstruction proxies are labeled; codec cycles are real",
      "codecs": ["h264", "hevc", "av1", "vp9", "prores", "av2"],
      "realtime_claim": false
    },
    "native_compressed_syntax_lab": {
      "execution": "offline_external_transplication",
      "entrypoint": "scripts/process_native_syntax_glitch.py",
      "sdk_entrypoint": "Tools/process_native_syntax_glitch.py",
      "helper": "scripts/native_syntax_glitch.py",
      "sdk_helper": "Tools/native_syntax_glitch.py",
      "installer": "scripts/install_ffglitch_reference.py",
      "sdk_installer": "Tools/install_ffglitch_reference.py",
      "catalog": "resources/codec-lab-effects.json",
      "effect_count": 8,
      "codec": "mpeg2",
      "container": "avi",
      "dependency": "external_FFglitch_ffedit_0.10.2_GPL-2.0-or-later",
      "persistent_evidence": [
        "source_bitstream",
        "exported_syntax_json",
        "mutated_syntax_json",
        "damaged_bitstream",
        "salvaged_intermediate",
        "ffedit_logs",
        "sha256",
        "codec_probe",
        "json_report"
      ],
      "h264_hevc_direct_support": "not_implemented_fail_closed",
      "realtime_claim": false
    },
    "analysis_and_evolutionary_lab": {
      "execution": "offline_process",
      "entrypoint": "scripts/process_codec_lab.py",
      "sdk_entrypoint": "Tools/process_codec_lab.py",
      "search_entrypoint": "scripts/evolutionary_codec_search.py",
      "sdk_search_entrypoint": "Tools/evolutionary_codec_search.py",
      "effect_count": 8,
      "token_free_search": true,
      "resume_state": true,
      "realtime_claim": false
    },
    "structured_bitstream_lab": {
      "execution": "offline_isolated_process",
      "entrypoint": "scripts/process_structured_codec_glitch.py",
      "sdk_entrypoint": "Tools/process_structured_codec_glitch.py",
      "catalog": "resources/codec-lab-effects.json",
      "effect_count": 6,
      "codecs": ["h264", "hevc", "av1"],
      "may_produce_invalid_bitstream": true,
      "realtime_claim": false
    },
    "transport_glitch_lab": {
      "execution": "offline_isolated_process",
      "entrypoint": "scripts/process_transport_glitch.py",
      "sdk_entrypoint": "Tools/process_transport_glitch.py",
      "catalog": "resources/codec-lab-effects.json",
      "effect_count": 3,
      "transport_models": [
        "mpegts",
        "rfc6184_h264_offline_packet_model",
        "hls_mpegts"
      ],
      "network_capture": false,
      "may_produce_invalid_bitstream": true,
      "realtime_claim": false
    },
    "metadata_glitch_lab": {
      "execution": "offline_process",
      "entrypoint": "scripts/process_metadata_glitch.py",
      "sdk_entrypoint": "Tools/process_metadata_glitch.py",
      "catalog": "resources/codec-lab-effects.json",
      "effect_count": 2,
      "codecs": ["h264", "hevc"],
      "realtime_claim": false
    }
  },
  "macos_link_frameworks": [
    "Foundation", "Metal", "CoreImage", "CoreGraphics", "CoreMedia",
    "CoreVideo", "VideoToolbox"
  ],
  "runtime_resources": {
    "Presets": "required_by_original_and_spatial_image_lanes",
    "glic_realtime.metallib": "required_by_metal_image_lanes",
    "selected-presets.json": "optional_data_copy_for_inspection_and_exchange",
    "integration-manifest.json": "optional_machine_readable_integration_contract",
    "offline-codec-effects.json": "optional_offline_packet_glitch_catalog",
    "codec-lab-effects.json": "optional_realtime_and_offline_codec_lab_catalog_with_implementation_levels"
  },
  "threading": {
    "image_context": "one_serial_processing_queue_per_context",
    "codec_submit": "nonblocking_and_may_return_backpressure",
    "prepare": "control_or_background_queue_only",
    "render_callback": "process_or_submit_only",
    "context_thread_safety": "not_concurrently_thread_safe"
  },
  "realtime_acceptance": {
    "minimum_width": 960,
    "minimum_height": 540,
    "minimum_frames_per_second": 20,
    "maximum_p95_frame_milliseconds": 50,
    "codec_requires_hardware_encoder": true,
    "codec_requires_hardware_decoder": true
  },
  "fail_closed_rules": [
    "do_not_route_codec_presets_to_glic_metal_context",
    "do_not_route_original_or_spatial_presets_to_codec_controls",
    "do_not_call_prepare_from_a_render_or_capture_callback",
    "do_not_share_one_context_across_concurrent_streams",
    "do_not_modify_compressed_videotoolbox_payload_bytes",
    "do_not_run_offline_packet_glitches_inside_realtime_callbacks",
    "do_not_decode_damaged_bitstreams_in_the_host_process",
    "do_not_claim_decoded_reconstruction_proxies_are_native_codec_syntax_hooks",
    "do_not_route_direct_h264_or_hevc_entropy_edits_to_the_mpeg2_ffglitch_lane",
    "do_not_substitute_av1_for_av2_when_avm_is_unavailable",
    "do_not_claim_pixel_exact_equivalence_with_processing_glic"
  ],
  "verification": [
    "python3 scripts/check_public_release.py --source .",
    "cmake --build build --parallel",
    "ctest --test-dir build --output-on-failure"
  ],
  "documentation": {
    "quickstart": "docs/DOWNSTREAM_QUICKSTART.md",
    "human": "docs/EMBEDDING.md",
    "agent": "docs/AI_INTEGRATION.md",
    "codec": "docs/CODEC_GLITCH.md",
    "multicodec": "docs/MULTICODEC_GLITCH.md",
    "offline_packet_glitch": "docs/OFFLINE_PACKET_GLITCH.md",
    "codec_lab": "docs/CODEC_LAB.md",
    "native_compressed_syntax": "docs/NATIVE_SYNTAX_GLITCH.md",
    "glitch_expansion": "docs/GLITCH_EXPANSION.md"
  }
}
